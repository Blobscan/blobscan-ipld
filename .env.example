# Copy to .env and fill in required values.
# Docker Compose reads this file automatically.

# ── Compose ───────────────────────────────────────────────────────────────────

# Use docker-compose.all.yml to run multiple networks from a single file.
# Set COMPOSE_PROFILES to a comma-separated list of networks to enable.
# Example: sepolia only, or mainnet+sepolia, etc.
COMPOSE_FILE=docker-compose.all.yml
COMPOSE_PROFILES=sepolia

# Available profiles: mainnet, sepolia, hoodi, gnosis
# postgres and ipfs always start regardless of profiles.

# ── Postgres ──────────────────────────────────────────────────────────────────

POSTGRES_PASSWORD=changeme

# ── Beacon RPC endpoints ──────────────────────────────────────────────────────

# Mainnet beacon node REST API (used by docker-compose.yml)
MAINNET_BEACON_RPC=http://localhost:5052

# Sepolia beacon node REST API (used by docker-compose.sepolia.yml)
SEPOLIA_BEACON_RPC=http://localhost:5052

# Hoodi beacon node REST API (used by docker-compose.hoodi.yml)
HOODI_BEACON_RPC=http://localhost:5052

# ── Execution-layer RPC endpoints (optional) ─────────────────────────────────
# When set, blobs are enriched with their EL transaction hash, block number, and
# block hash before being saved to the DB. Requires the matching beacon RPC.
# Leave blank to skip EL enrichment (those DB columns stay empty).

# Mainnet execution-layer JSON-RPC (used by docker-compose.yml / .all.yml)
#MAINNET_EXECUTION_RPC=http://localhost:8545

# Sepolia execution-layer JSON-RPC (used by docker-compose.sepolia.yml / .all.yml)
#SEPOLIA_EXECUTION_RPC=http://localhost:8545

# Hoodi execution-layer JSON-RPC (used by docker-compose.hoodi.yml / .all.yml)
#HOODI_EXECUTION_RPC=http://localhost:8545

# Gnosis execution-layer JSON-RPC (used by docker-compose.gnosis.yml / .all.yml)
#GNOSIS_EXECUTION_RPC=http://localhost:8545

# ── Application settings (passed to containers via docker-compose env) ────────
# These override built-in defaults. Uncomment to change.

# Network name: mainnet, sepolia, gnosis, hoodi
# Set per-service in the compose file; override here only for single-network setups
#NETWORK_NAME=mainnet

# HTTP timeout for beacon requests (default: 60s)
#BEACON_TIMEOUT=60s

# Max requests/second to beacon RPC (~80-90% of provider limit)
#BEACON_RATE_LIMIT=100

# Token bucket burst size (default: 32)
#BEACON_RATE_BURST=32

# Initial backoff on HTTP 429 errors (doubles each time, capped at 60s; default: 1s)
#BEACON_429_BACKOFF=1s

# Root directory for state file and generated data (default set per-service in compose)
#DATA_DIR=/data

# Directory for per-epoch CAR v2 files (default: $DATA_DIR/car)
#CAR_DIR=/car

# PostgreSQL connection string (default set per-service in compose)
#POSTGRES_DSN=postgres://blobscan:changeme@postgres:5432/ipld_mainnet?sslmode=disable

# IPFS HTTP RPC address — multiaddr or plain URL (default set per-service in compose)
#IPFS_API_ADDR=/dns4/ipfs/tcp/5001

# Recursively pin each epoch CID after upload (default: false)
#IPFS_PIN_ON_ADD=false

# Compute CIDs only; skip all IPFS interaction (default: false)
#IPFS_SKIP_UPLOAD=false

# Parallel block/put requests per epoch (default: 16)
#IPFS_UPLOAD_WORKERS=16

# Parallel blob-processing goroutines, set near vCPU count (default: 16)
#GENERATOR_WORKERS=16

# Parallel slot fetches per epoch, bounded by BEACON_RATE_LIMIT (default: 16)
#GENERATOR_BEACON_WORKERS=16

# Parallel epoch builders in the backfill pipeline (default: 4)
# Increase for local beacon nodes; decrease if hitting rate limits
#BACKFILL_EPOCH_WORKERS=4

# How often to poll for new finalized epochs (default: 12s)
#GENERATOR_POLL_INTERVAL=12s

# First epoch to process; defaults to Dencun fork epoch per network:
#   mainnet=269568  sepolia=132608  gnosis=889856  hoodi=0
#GENERATOR_START_EPOCH=0

# Blob count per epoch above which HAMT sharding is used (default: 5000)
#GENERATOR_HAMT_THRESHOLD=5000

# Resume from last processed epoch instead of GENERATOR_START_EPOCH (default: false)
#GENERATOR_SKIP_EXISTING_EPOCHS=false

# Address for the HTTP push API; leave unset to disable
#GENERATOR_API_LISTEN=:8080

# Max epochs per NetworkRoot page, must be >= 1000 (default: 10000)
#NETWORK_ROOT_PAGE_SIZE=10000

# Blobscan REST API base URL for reporting CID references (optional)
#BLOBSCAN_API_URL=http://localhost:3001

# Blobscan API key — value of IPFS_STORAGE_API_KEY in blobscan (optional)
#BLOBSCAN_API_KEY=
